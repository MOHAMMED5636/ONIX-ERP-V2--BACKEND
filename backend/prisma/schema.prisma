  membershipIssueDate      DateTime?
  membershipExpiry         DateTime?
  membershipLegalStatus    String?
  trakheesId               String?
  practiceRegisterNumber   String?
  practiceRegisterIssueDate DateTime?
  practiceRegisterExpiry   DateTime?
  municipalityClassification String?
  establishmentMolNumber   String?
  molCardIssueDate         DateTime?
  molCardExpiry            DateTime?
  sponsorName              String?
  establishmentLocation    String?  @db.Text
  subscriptionStartDate    DateTime?
  subscriptionEndDate      DateTime?

