generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  password            String
  firstName           String
  lastName            String
  role                UserRole @default(ADMIN)
  isActive            Boolean  @default(true)
  forcePasswordChange Boolean  @default(false) // Force password change on first login
  loginOtp            String?  // OTP for passwordless login
  loginOtpExpiry      DateTime? // OTP expiration time (10 minutes)
  phone               String?
  department          String?
  position            String?
  jobTitle            String? // Job title/designation (e.g., "Senior Engineer", "Project Manager")
  photo               String? // Photo URL or file path
  employeeId          String?  @unique // Employee ID/Number
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String? // ID of admin who created this user

  // Employee Directory - Personal Info
  employeeType String? // Employee type (Full-time, Part-time, Contract, etc.)
  status       String? // Employee status (Active, Inactive, Pending, etc.)
  userAccount  Boolean @default(false) // Whether user account should be created

  // Employee Directory - Personal Details
  gender         String? // Gender (Male, Female, Other)
  maritalStatus  String? // Marital status (Single, Married, Divorced, Widowed)
  nationality    String? // Nationality
  birthday       DateTime? // Date of birth
  childrenCount  Int? // Number of children
  currentAddress String? // Current residential address

  // Employee Directory - Contact Info (stored as JSON strings)
  phoneNumbers   String? @db.Text // JSON array of phone numbers
  emailAddresses String? @db.Text // JSON array of email addresses

  // Employee Directory - Company Info
  company           String? // Company name
  companyLocation   String? // Company location/branch
  managerId         String? // Line manager ID (references User)
  manager           User?     @relation("LineManager", fields: [managerId], references: [id])
  managedEmployees  User[]    @relation("LineManager") // Employees managed by this user
  attendanceProgram String? // Attendance program name
  joiningDate       DateTime? // Date of joining
  exitDate          DateTime? // Date of exit/termination
  isLineManager     Boolean   @default(false) // Whether this employee is a line manager

  // Employee Directory - Legal Documents Info
  passportNumber     String?
  passportIssueDate  DateTime?
  passportExpiryDate DateTime?
  passportAttachment String? // File path/URL for passport document

  nationalIdNumber     String?
  nationalIdExpiryDate DateTime?
  nationalIdAttachment String? // File path/URL for national ID document

  residencyNumber     String?
  residencyExpiryDate DateTime?
  residencyAttachment String? // File path/URL for residency document
  visaNumber          String? // UAE visa / file number (UI "Visa number")

  insuranceNumber     String?
  insuranceExpiryDate DateTime?
  insuranceAttachment String? // File path/URL for insurance document

  drivingLicenseNumber     String?
  drivingLicenseExpiryDate DateTime?
  drivingLicenseAttachment String? // File path/URL for driving license document

  labourIdNumber     String?
  labourIdExpiryDate DateTime?
  labourIdAttachment String? // File path/URL for labour ID document

  remarks String? @db.Text // Additional remarks/notes

  // Relations
  assignedTenders  TenderInvitation[]  @relation("AssignedEngineer")
  createdProjects  Project[]
  assignedProjects ProjectAssignment[] @relation("AssignedEmployee")
  assignedTasks    TaskAssignment[]
  assignedTaskSubtasks Task[] @relation("AssignedTaskEmployee") // Subtasks/child tasks assigned to this employee
  taskDelegationsAsOriginal  TaskDelegation[] @relation("DelegationOriginal")
  taskDelegationsAsNew       TaskDelegation[] @relation("DelegationNew")
  taskDelegationsAsDelegator TaskDelegation[] @relation("DelegationBy")
  createdTemplates QuestionnaireTemplate[] @relation("TemplateCreator")
  questionnaireResponses QuestionnaireResponse[] @relation("QuestionnaireRespondent")

  createdFeedbackSurveys      FeedbackSurvey[]              @relation("FeedbackSurveyCreator")
  ownedFeedbackSurveys        FeedbackSurvey[]              @relation("FeedbackSurveyOwner")
  feedbackSurveyAssignments FeedbackSurveyAssignment[]
  feedbackSurveyResponses   FeedbackSurveyResponse[]
  feedbackSurveySubmissions FeedbackSurveySubmission[]
  feedbackSurveyShareLinksCreated FeedbackSurveyShareLink[] @relation("FeedbackShareLinkCreator")
  feedbackSurveyCollaborations    FeedbackSurveyCollaborator[]

  // HR Relations
  managedDepartments    Department[]    @relation("DepartmentManager")
  managedSubDepartments SubDepartment[] @relation("SubDepartmentManager")
  managedPositions      Position[]      @relation("PositionManager")

  // Chat Relations
  sentMessages ProjectMessage[] @relation("MessageSender")

  // Contract Relations
  createdContracts  Contract[] @relation("ContractCreator")
  approvedContracts Contract[] @relation("ContractApprover")
  assignedContracts Contract[] @relation("AssignedContractManager")

  // Dashboard preferences
  dashboardWidgetPreference DashboardWidgetPreference?

  // Attendance Relations
  attendances Attendance[] @relation("UserAttendances")

  // Leave balance (annual leave days per year; used for balance tracking)
  annualLeaveBalance Int? @default(25)

  // Leave Relations
  leaveRequests           Leave[] @relation("LeaveRequester")
  approvedLeaves          Leave[] @relation("LeaveApprover")
  rejectedLeaves          Leave[] @relation("LeaveRejector")
  leaveManagerActions     Leave[] @relation("LeaveManagerAction")

  // Labour employee flag - when true, LabourDetails record exists
  isLabour         Boolean  @default(false)
  labourDetails    LabourDetails?

  companyPoliciesCreated           CompanyPolicy[]                 @relation("CompanyPolicyCreator")
  companyPolicyAcknowledgements    CompanyPolicyAcknowledgement[]

  activityLogs UserActivityLog[]

  // Salary relations
  salaryStructures SalaryStructure[]
  salaryAuditLogs SalaryAuditLog[] @relation("SalaryAuditor")

  // Payroll relations
  payrollLines PayrollLine[] @relation("PayrollEmployee")
  payrollApprovals PayrollApproval[] @relation("PayrollApprover")
  payrollAuditLogs PayrollAuditLog[] @relation("PayrollAuditor")

  employeeChangeLogsAsSubject EmployeeChangeLog[] @relation("EmployeeChangeSubject")
  employeeChangeLogsAsActor   EmployeeChangeLog[] @relation("EmployeeChangeActor")

  /// Extra org-chart positions (user still keeps primary `department` / `position` / `jobTitle`).
  positionAssignments         EmployeePositionAssignment[] @relation("EmployeePositionAssignmentSubject")
  authoredPositionAssignments EmployeePositionAssignment[] @relation("PositionAssignmentAssigner")

  /// System feedback tickets (visible to Admin only).
  systemFeedbacksSubmitted SystemFeedback[] @relation("SystemFeedbackSubmitter")
  systemFeedbacksReviewed  SystemFeedback[] @relation("SystemFeedbackReviewer")

  @@map("users")
}

model DashboardWidgetPreference {
  id        String   @id @default(uuid())
  userId    String   @unique
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dashboard_widget_preferences")
}

/// User-submitted ERP feedback; only Admins can list/review. Not the same as scheduled feedback surveys.
enum SystemFeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

model SystemFeedback {
  id                   String               @id @default(uuid())
  submitterId          String
  submitter            User                 @relation("SystemFeedbackSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  message              String               @db.Text
  category             String? // e.g. BUG, UX, FEATURE, GENERAL
  pageUrl              String? // optional browser path when submitted
  screenshotFilename   String? // stored under uploads/feedback/
  status               SystemFeedbackStatus @default(OPEN)
  adminNotes           String?              @db.Text
  reviewedById         String?
  reviewedBy           User?                @relation("SystemFeedbackReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt           DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([submitterId, createdAt])
  @@index([status, createdAt])
  @@map("system_feedback")
}

/// HR/Admin audit trail for employee profile updates (directory modal).
model EmployeeChangeLog {
  id            String   @id @default(uuid())
  employeeId    String
  employee      User     @relation("EmployeeChangeSubject", fields: [employeeId], references: [id], onDelete: Cascade)
  changedById   String?
  changedBy     User?    @relation("EmployeeChangeActor", fields: [changedById], references: [id], onDelete: SetNull)
  changedByRole String
  fieldKey      String
  fieldLabel    String
  oldValue      String?  @db.Text
  newValue      String?  @db.Text
  reason        String   @db.Text
  createdAt     DateTime @default(now())

  @@index([employeeId, createdAt])
  @@map("employee_change_logs")
}

/// Login/logout, page views, and explicit actions — Admin/HR activity calendar (not attendance/leave).
model UserActivityLog {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType       String
  module          String?
  action          String?
  metadata        Json?
  durationSeconds Int?
  createdAt       DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("user_activity_logs")
}

model LabourDetails {
  id                          String    @id @default(uuid())
  userId                      String    @unique
  user                        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  molNumber                   String?
  contractTotalSalary         Decimal?  @db.Decimal(12, 2)
  basicSalary                 Decimal?  @db.Decimal(12, 2)
  allowance1                  Decimal?  @db.Decimal(12, 2)
  allowance2                  Decimal?  @db.Decimal(12, 2)
  healthInsuranceExpiryDate   DateTime?
  vehicleNumber               String?
  vehicleType                 String?
  vehicleRegistrationExpiry   DateTime?
  shoeSize                    String?
  assetsCustodyItems          String?   @db.Text
  accommodationRoomNumber     String?
  accommodationContractExpiry DateTime?
  roomAllocationDate          DateTime?

  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  @@map("labour_details")
}

// ============================================================
// Salary Management Module (HR/Admin/Ramiz) - per-employee
// ============================================================

enum SalaryAllowanceType {
  HRA
  TRAVEL
  BONUS
  OTHER
}

enum SalaryDeductionType {
  LEAVE
  LATE_PENALTY
  LOAN
  OTHER_MANUAL
}

// How the deduction value should be interpreted.
// - FIXED: fixed amount per payroll period
// - PER_DAY: multiplied by number of days (leave/unpaid etc.)
// - PER_MINUTE: multiplied by number of minutes late/early
// - PERCENTAGE: multiplied by a base amount (e.g., gross) using `value` as %
enum SalaryDeductionMode {
  FIXED
  PER_DAY
  PER_MINUTE
  PERCENTAGE
}

enum SalaryIncrementType {
  MONTHLY
  YEARLY
  MANUAL
  OTHER
}

enum SalaryAuditAction {
  CREATE
  UPDATE
  DELETE
  ADD_ALLOWANCE
  ADD_DEDUCTION
  ADD_INCREMENT
}

model SalaryStructure {
  id                     String   @id @default(uuid())
  employeeId             String
  employee               User     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  effectiveFrom          DateTime

  // Core salary structure
  basicSalary            Decimal? @db.Decimal(12, 2)
  perHourRate            Decimal? @db.Decimal(12, 2)
  contractSalaryAmount  Decimal? @db.Decimal(12, 2)

  notes                  String?  @db.Text

  allowances             SalaryAllowance[]
  deductions             SalaryDeduction[]
  increments             SalaryIncrementHistory[]
  auditLogs              SalaryAuditLog[]

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([employeeId, effectiveFrom])
  @@index([employeeId, effectiveFrom])
  @@map("salary_structures")
}

model SalaryAllowance {
  id               String              @id @default(uuid())
  salaryStructureId String
  salaryStructure   SalaryStructure   @relation(fields: [salaryStructureId], references: [id], onDelete: Cascade)

  allowanceType    SalaryAllowanceType
  amount           Decimal?           @db.Decimal(12, 2)
  notes            String?            @db.Text

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([salaryStructureId])
  @@map("salary_allowances")
}

model SalaryDeduction {
  id               String            @id @default(uuid())
  salaryStructureId String
  salaryStructure   SalaryStructure @relation(fields: [salaryStructureId], references: [id], onDelete: Cascade)

  deductionType    SalaryDeductionType
  mode             SalaryDeductionMode @default(FIXED)

  // Single numeric value interpreted based on `mode`.
  // Examples:
  // - FIXED: fixed AED deduction per payroll period
  // - PER_DAY: AED per day
  // - PER_MINUTE: AED per minute
  // - PERCENTAGE: percent value (e.g., 5 means 5%)
  value            Decimal?         @db.Decimal(12, 2)
  notes            String?         @db.Text

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([salaryStructureId])
  @@map("salary_deductions")
}

model SalaryIncrementHistory {
  id               String          @id @default(uuid())
  salaryStructureId String
  salaryStructure   SalaryStructure @relation(fields: [salaryStructureId], references: [id], onDelete: Cascade)

  effectiveDate    DateTime
  incrementType    SalaryIncrementType
  amount           Decimal?         @db.Decimal(12, 2)
  note             String?          @db.Text

  createdAt        DateTime        @default(now())

  @@index([salaryStructureId, effectiveDate])
  @@map("salary_increment_history")
}

model SalaryAuditLog {
  id               String          @id @default(uuid())

  salaryStructureId String?
  salaryStructure   SalaryStructure? @relation(fields: [salaryStructureId], references: [id], onDelete: SetNull)

  action           SalaryAuditAction
  details          Json?

  performedById    String?
  performedBy      User?           @relation("SalaryAuditor", fields: [performedById], references: [id], onDelete: SetNull)

  createdAt        DateTime        @default(now())

  @@index([createdAt])
  @@map("salary_audit_logs")
}

// ============================================================
// Payroll Module (HR/Admin) - backend payroll runs
// ============================================================

model PayrollSettings {
  id                    String   @id @default(uuid())
  gracePeriodMinutes    Int      @default(15)
  lateDeductionPerMinute Decimal @db.Decimal(10, 2) @default(0.5)
  absenceDeductionType  String   @default("DAILY")
  absenceDeductionValue Decimal  @db.Decimal(10, 2) @default(1.0)
  unpaidLeaveDeductionType String @default("DAILY")
  unpaidLeaveDeductionValue Decimal @db.Decimal(10, 2) @default(1.0)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  updatedBy             String?

  @@map("payroll_settings")
}

model PayrollRun {
  id              String          @id @default(uuid())
  periodStart     DateTime        @db.Date
  periodEnd        DateTime        @db.Date
  periodMonth     Int
  periodYear      Int

  status          PayrollStatus   @default(DRAFT)
  totalEmployees  Int             @default(0)
  totalGross      Decimal         @db.Decimal(12, 2) @default(0)
  totalDeductions Decimal         @db.Decimal(12, 2) @default(0)
  totalNet        Decimal         @db.Decimal(12, 2) @default(0)

  hrApprovedById   String?
  hrApprovedAt     DateTime?
  financeApprovedById String?
  financeApprovedAt   DateTime?
  finalApprovedById String?
  finalApprovedAt   DateTime?
  lockedAt         DateTime?

  settingsSnapshot Json?

  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lines           PayrollLine[]
  approvals       PayrollApproval[]
  auditLogs       PayrollAuditLog[]

  @@unique([periodMonth, periodYear])
  @@index([status])
  @@index([periodYear, periodMonth])
  @@map("payroll_runs")
}

enum PayrollStatus {
  DRAFT
  HR_PENDING
  HR_APPROVED
  FINANCE_PENDING
  FINANCE_APPROVED
  FINAL_APPROVED
  LOCKED
}

model PayrollLine {
  id              String   @id @default(uuid())
  payrollRunId    String
  payrollRun      PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  employeeId      String
  employee        User     @relation("PayrollEmployee", fields: [employeeId], references: [id])

  snapshotEmployeeId    String?
  snapshotBasicSalary   Decimal @db.Decimal(12, 2)
  snapshotAllowance1    Decimal @db.Decimal(12, 2) @default(0)
  snapshotAllowance2    Decimal @db.Decimal(12, 2) @default(0)
  snapshotTotalAllowances Decimal @db.Decimal(12, 2) @default(0)
  snapshotDepartment    String?

  grossSalary     Decimal @db.Decimal(12, 2)
  totalDeductions Decimal @db.Decimal(12, 2) @default(0)
  netSalary       Decimal @db.Decimal(12, 2)

  totalWorkingDays    Int @default(0)
  totalAbsentDays     Int @default(0)
  totalLateInstances  Int @default(0)
  totalLateMinutes    Int @default(0)
  totalEarlyLeaveMinutes Int @default(0)

  paidLeaveDays       Int @default(0)
  unpaidLeaveDays     Int @default(0)

  absenceDeduction     Decimal @db.Decimal(12, 2) @default(0)
  lateDeduction        Decimal @db.Decimal(12, 2) @default(0)
  unpaidLeaveDeduction Decimal @db.Decimal(12, 2) @default(0)
  manualAdjustments    Decimal @db.Decimal(12, 2) @default(0)
  adjustmentNotes      String? @db.Text

  payslipGenerated     Boolean @default(false)
  payslipGeneratedAt   DateTime?
  payslipPath          String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
  @@index([payrollRunId])
  @@map("payroll_lines")
}

model PayrollApproval {
  id            String          @id @default(uuid())
  payrollRunId  String
  payrollRun    PayrollRun      @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  stage         PayrollApprovalStage

  approvedById  String?
  approvedBy    User?   @relation("PayrollApprover", fields: [approvedById], references: [id])

  approvedAt    DateTime?
  comments      String? @db.Text
  rejected      Boolean @default(false)
  rejectionReason String? @db.Text

  createdAt     DateTime @default(now())

  @@index([payrollRunId])
  @@index([stage])
  @@map("payroll_approvals")
}

enum PayrollApprovalStage {
  HR_REVIEW
  FINANCE_REVIEW
  FINAL_APPROVAL
}

model PayrollAuditLog {
  id            String   @id @default(uuid())
  payrollRunId  String
  payrollRun    PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  action        String
  performedById String?
  performedBy   User? @relation("PayrollAuditor", fields: [performedById], references: [id], onDelete: SetNull)

  details       Json?
  createdAt     DateTime @default(now())

  @@index([payrollRunId])
  @@index([action])
  @@map("payroll_audit_logs")
}

enum UserRole {
  ADMIN
  TENDER_ENGINEER
  PROJECT_MANAGER
  CONTRACTOR
  EMPLOYEE
  HR
  MANAGER
}

model Client {
  id              String    @id @default(uuid())
  referenceNumber String    @unique
  name            String
  isCorporate     String // "Person" or "Company"
  leadSource      String?
  rank            String?
  email           String?
  phone           String?
  address         String?   @db.Text
  nationality     String?
  idNumber        String?
  idExpiryDate    DateTime? // ID expiry date
  passportNumber  String?
  birthDate       DateTime?

  // Client representative (optional)
  representativeName        String?
  representativeEmail       String?
  representativePhone       String?
  representativeNationality String?
  representativeIdNumber    String?
  representativeIdExpiryDate DateTime?
  representativePassportNumber String?
  representativeBirthDate   DateTime?
  representativeAddress     String?   @db.Text

  representativeType        String? // "Person" or "Company"
  representativeLeadSource  String?
  representativeRank        String?

  // Representative company info (if representativeType === "Company")
  representativeCorporateName     String?
  representativeWebsite           String?
  representativeLicenseNumber     String?
  representativeCompanyAddress    String? @db.Text
  representativeCompanyDescription String? @db.Text
  representativeTrnNumber         String?
  representativeIbanNumber        String?
  representativePowerOfAttorneyPath String?
  representativePowerOfAttorneyOriginalName String?

  // Document upload fields
  documentType       String? // Document Type / Category (primary)
  documentAttachment String? // File path/URL for primary uploaded document
  documentAttachments String? @db.Text // JSON array of { documentType, path } for multiple documents

  // Undertaking letter (project undertaking) - optional
  undertakingLetterPath String?
  undertakingLetterOriginalName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  projects  Project[]
  tenders   Tender[]
  contracts Contract[]

  @@map("clients")
}

// Atomic per-year counter for client reference numbers: O-CL-YYYY/NNNN
model ClientReferenceSequence {
  year       Int @id
  lastNumber Int @default(0)

  @@map("client_reference_sequences")
}

model Project {
  id               String        @id @default(uuid())
  projectNumber    Int           @unique @default(autoincrement())
  name             String
  referenceNumber  String        @unique
  pin              String?       @unique // Project Identification Number
  clientId         String?
  client           Client?       @relation(fields: [clientId], references: [id])
  owner            String?
  description      String?
  status           ProjectStatus @default(OPEN)
  projectManager   String?       @db.VarChar(100) // Free-text project manager name (not linked to users)
  startDate        DateTime?
  endDate          DateTime?
  deadline         DateTime?
  planDays         Int? // Planned duration in days
  remarks          String? // General remarks
  assigneeNotes    String? // Notes from assignee
  
  // Location & Project Details (from contracts)
  location         String? // Location string (can be coordinates or address)
  makaniNumber     String? // Makani number (UAE addressing system - 10 digits)
  plotNumber       String? // Plot number
  community        String? // Community name
  projectType      String? // Project type (e.g., "Residential", "Commercial", "Industrial")
  projectFloor     String? // Number of floors (stored as string for flexibility)
  developerProject String? // Developer name/project
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  createdBy         String?
  creator           User?               @relation(fields: [createdBy], references: [id])
  tenders           Tender[]
  documents         Document[]
  assignedEmployees ProjectAssignment[] @relation("ProjectAssignments")
  tasks             Task[]
  checklists        ProjectChecklist[]
  attachments       ProjectAttachment[]
  chats             ProjectChat[]
  contracts         Contract[]
  questionnaireQuestions QuestionnaireQuestion[]
  questionnaireAssignments QuestionnaireAssignment[]

  @@map("projects")
}

enum ProjectStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
  CLOSED
}

model Tender {
  id              String       @id @default(uuid())
  projectId       String
  project         Project      @relation(fields: [projectId], references: [id])
  name            String
  referenceNumber String       @unique
  clientId        String?
  client          Client?      @relation(fields: [clientId], references: [id])
  status          TenderStatus @default(OPEN)

  // Tender Details
  scopeOfWork              String?
  technicalDrawingsLink    String?
  hasInvitationFees        Boolean   @default(false)
  invitationFeeAmount      Decimal?  @db.Decimal(10, 2)
  tenderAcceptanceDeadline DateTime?
  bidSubmissionDeadline    DateTime?
  additionalNotes          String?

  // Attachment
  attachmentFile String? // File path or URL

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  invitations          TenderInvitation[]
  technicalSubmissions TechnicalSubmission[]

  @@map("tenders")
}

enum TenderStatus {
  OPEN
  CLOSED
  AWARDED
  REJECTED
  CANCELLED
}

model TenderInvitation {
  id              String           @id @default(uuid())
  tenderId        String
  tender          Tender           @relation(fields: [tenderId], references: [id])
  engineerId      String
  engineer        User             @relation("AssignedEngineer", fields: [engineerId], references: [id])
  invitationToken String           @unique
  status          InvitationStatus @default(PENDING)
  assignedAt      DateTime         @default(now())
  acceptedAt      DateTime?

  @@map("tender_invitations")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model TechnicalSubmission {
  id          String           @id @default(uuid())
  tenderId    String
  tender      Tender           @relation(fields: [tenderId], references: [id])
  engineerId  String
  submittedAt DateTime         @default(now())
  status      SubmissionStatus @default(SUBMITTED)

  // Relations
  documents Document[]

  @@map("technical_submissions")
}

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model Document {
  id            String  @id @default(uuid())
  module        String // "PRJ", "HR", "CLI", "FIN", "GEN"
  entityCode    String // Reference number
  documentType  String // "CNTR", "DRW", "RPT", etc.
  year          Int
  sequence      String
  referenceCode String  @unique
  fileName      String
  filePath      String
  fileUrl       String?
  fileSize      Int
  mimeType      String

  // Relations
  projectId    String?
  project      Project?             @relation(fields: [projectId], references: [id])
  submissionId String?
  submission   TechnicalSubmission? @relation(fields: [submissionId], references: [id])

  uploadedBy String?
  uploadedAt DateTime @default(now())

  @@map("documents")
}

// Project Assignment - Links employees to projects
model ProjectAssignment {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation("ProjectAssignments", fields: [projectId], references: [id], onDelete: Cascade)
  employeeId String
  employee   User     @relation("AssignedEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())
  assignedBy String? // Admin/HR who assigned
  role       String? // Role in project (e.g., "Engineer", "Manager", "Supervisor")

  @@unique([projectId, employeeId])
  @@map("project_assignments")
}

// Task Model
model Task {
  id             String       @id @default(uuid())
  title          String
  description    String?
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentTaskId   String?      // For subtasks - references parent task
  parentTask     Task?        @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks       Task[]       @relation("TaskSubtasks") // Child tasks/subtasks
  status         TaskStatus   @default(PENDING)
  // Workflow / dependency status (separate from general status to avoid breaking existing logic)
  workflowStatus TaskWorkflowStatus @default(NOT_STARTED)
  priority       TaskPriority @default(MEDIUM)
  startDate      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?
  estimatedHours Decimal?     @db.Decimal(10, 2)
  actualHours    Decimal?     @db.Decimal(10, 2)
  tags           String[] // Array of tags
  // Additional fields for subtasks/child tasks
  category       String?      // Task category (Design, Development, etc.)
  referenceNumber String?      // Reference number for subtask
  planDays       Int?         // Plan days for subtask
  remarks        String?      @db.Text // Remarks
  assigneeNotes  String?      @db.Text // Assignee notes
  assignedEmployeeId String?  // Assigned employee ID for subtasks/child tasks
  assignedEmployee User?      @relation("AssignedTaskEmployee", fields: [assignedEmployeeId], references: [id])
  location       String?      // Location
  makaniNumber   String?      // Makani number
  plotNumber     String?      // Plot number
  community      String?      // Community
  projectType    String?      // Project type
  projectFloor   String?      // Project floor
  developerProject String?     // Developer project
  predecessors   String?      @db.VarChar(500) // Task keys (e.g. "1.1" or "1.1,1.2") that must be completed before this task; used for locking
  // Normalized predecessor relation (used for strict sequencing)
  predecessorId  String?
  predecessor    Task?        @relation("TaskPredecessor", fields: [predecessorId], references: [id])
  dependents     Task[]       @relation("TaskPredecessor")
  // Simple execution order for project management (ascending per project/parent)
  taskOrder      Int?         @map("task_order")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdBy      String?

  // Relations
  assignments   TaskAssignment[]
  checklists    TaskChecklist[]
  attachments   TaskAttachment[]
  comments      TaskComment[]
  delegations   TaskDelegation[]   // Audit trail of task delegations
  questionnaireQuestions QuestionnaireQuestion[]
  questionnaireAssignments QuestionnaireAssignment[]

  @@map("tasks")
}

enum TaskWorkflowStatus {
  WAITING_FOR_PREDECESSOR
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Task Assignment - Links employees to tasks
model TaskAssignment {
  id         String               @id @default(uuid())
  taskId     String
  task       Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employeeId String
  employee   User                 @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  assignedAt DateTime             @default(now())
  assignedBy String?
  status     TaskAssignmentStatus @default(PENDING)

  @@unique([taskId, employeeId])
  @@map("task_assignments")
}

enum TaskAssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DELEGATED  // Original assignee after delegating to someone else
}

// Task Delegation - Audit trail when employee delegates a child/subtask to another employee
model TaskDelegation {
  id                 String   @id @default(uuid())
  taskId             String
  task               Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  originalAssigneeId String
  originalAssignee   User     @relation("DelegationOriginal", fields: [originalAssigneeId], references: [id], onDelete: Cascade)
  newAssigneeId      String
  newAssignee        User     @relation("DelegationNew", fields: [newAssigneeId], references: [id], onDelete: Cascade)
  delegatedById      String   // User who performed delegation (typically original assignee)
  delegatedBy        User     @relation("DelegationBy", fields: [delegatedById], references: [id], onDelete: Cascade)
  delegatedAt        DateTime @default(now())
  reason             String?  @db.Text

  @@index([taskId])
  @@index([originalAssigneeId])
  @@index([newAssigneeId])
  @@index([delegatedAt])
  @@map("task_delegations")
}

// Questionnaire Template - Reusable checklist templates
model QuestionnaireTemplate {
  id          String    @id @default(uuid())
  name        String    // Template name (e.g., "Safety Checklist", "Quality Control")
  description String?
  isActive    Boolean   @default(true)
  isLocked    Boolean   @default(false) // Locked templates cannot be modified
  createdBy   String?   // User ID who created the template
  creator     User?     @relation("TemplateCreator", fields: [createdBy], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Questions in this template
  questions   QuestionnaireQuestion[]
  
  // Assignments - where this template is used
  assignments QuestionnaireAssignment[]

  @@map("questionnaire_templates")
}

// Questionnaire Question - Questions within a template
model QuestionnaireQuestion {
  id           String              @id @default(uuid())
  templateId   String?
  template     QuestionnaireTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  // Question details
  questionText String              // The actual question
  description  String?             // Optional description/instructions
  order        Int                 @default(0) // Display order
  isRequired   Boolean             @default(true) // Whether answer is required
  
  // Assignment details (if not part of a template)
  projectId    String?
  project      Project?            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId       String?
  task         Task?               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  subtaskId    String?             // For sub-tasks (if you have a subtask model)
  
  // Status
  isLocked     Boolean             @default(false) // Locked questions cannot be answered
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  createdBy    String?             // User ID who created the question
  
  // Responses to this question
  responses    QuestionnaireResponse[]

  @@map("questionnaire_questions")
}

// Questionnaire Response - Employee answers to questions
model QuestionnaireResponse {
  id          String              @id @default(uuid())
  questionId  String
  question    QuestionnaireQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  // Response details
  answer      QuestionnaireAnswer // Selected option
  remarks     String?             // Optional remarks/notes
  
  // Tracking
  answeredBy  String              // Employee user ID
  employee    User                @relation("QuestionnaireRespondent", fields: [answeredBy], references: [id])
  answeredAt  DateTime            @default(now()) // Date and time of response
  
  // Status
  isLocked    Boolean             @default(false) // Locked responses cannot be modified
  
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([questionId, answeredBy]) // One response per employee per question
  @@map("questionnaire_responses")
}

// Enum for questionnaire answers
enum QuestionnaireAnswer {
  ACTION_PLAN_APPLIED
  NOT_AVAILABLE
  NOT_APPLIED
  PENDING
}

// Questionnaire Assignment - Links templates to Projects/Tasks/Sub-Tasks
model QuestionnaireAssignment {
  id          String              @id @default(uuid())
  templateId  String
  template    QuestionnaireTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  // Assignment target
  projectId   String?
  project     Project?            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId      String?
  task        Task?               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  subtaskId  String?              // For sub-tasks
  
  // Status
  isActive    Boolean             @default(true)
  assignedBy  String?             // User ID who assigned this template
  assignedAt  DateTime            @default(now())
  
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("questionnaire_assignments")
}

// --- Feedback & surveys → Dynamic Form Builder (sections, submissions, logic, sharing) ---
model FeedbackSurvey {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  dueDate     DateTime?
  /// DRAFT | PUBLISHED | CLOSED (legacy ACTIVE treated as PUBLISHED in API)
  status      String   @default("DRAFT")
  department  String?
  ownerId     String?
  owner       User?    @relation("FeedbackSurveyOwner", fields: [ownerId], references: [id])
  createdBy   String?
  creator     User?    @relation("FeedbackSurveyCreator", fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sections        FeedbackSurveySection[]
  questions       FeedbackSurveyQuestion[]
  assignments     FeedbackSurveyAssignment[]
  responses       FeedbackSurveyResponse[]
  submissions     FeedbackSurveySubmission[]
  settings        FeedbackSurveySettings?
  logicRules      FeedbackSurveyLogicRule[]
  shareLinks      FeedbackSurveyShareLink[]
  collaborators   FeedbackSurveyCollaborator[]
  actions         FeedbackSurveyAction[]

  @@map("feedback_surveys")
}

model FeedbackSurveySection {
  id          String   @id @default(uuid())
  surveyId    String
  survey      FeedbackSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions          FeedbackSurveyQuestion[]
  logicRulesAsTarget FeedbackSurveyLogicRule[] @relation("LogicTargetSection")

  @@index([surveyId])
  @@map("feedback_survey_sections")
}

model FeedbackSurveyQuestion {
  id           String   @id @default(uuid())
  surveyId     String
  survey       FeedbackSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  sectionId    String?
  section      FeedbackSurveySection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  questionText String
  description  String?
  order        Int      @default(0)
  /// SHORT_TEXT, LONG_TEXT, NUMBER, EMAIL, PHONE, SINGLE_CHOICE, MULTIPLE_CHOICE, DROPDOWN, DATE, TIME, FILE, RATING, LINEAR_SCALE, MATRIX; legacy TEXT maps to SHORT_TEXT
  questionType String   @default("SHORT_TEXT")
  options      String?  @db.Text
  placeholder  String?
  config       Json?
  validation   Json?
  isRequired   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  responses            FeedbackSurveyResponse[]
  answers              FeedbackSurveyAnswer[]
  logicRulesAsSource   FeedbackSurveyLogicRule[] @relation("LogicRuleSource")
  logicRulesTargetQuestion FeedbackSurveyLogicRule[] @relation("LogicRuleTargetQuestion")

  @@index([surveyId])
  @@index([sectionId])
  @@map("feedback_survey_questions")
}

model FeedbackSurveySettings {
  surveyId                 String    @id
  survey                   FeedbackSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  allowMultipleSubmissions Boolean   @default(false)
  requireLogin             Boolean   @default(true)
  closingDate              DateTime?
  notifyOnSubmit           Boolean   @default(false)
  confirmationMessage      String?   @db.Text
  allowEditAfterSubmit     Boolean   @default(false)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@map("feedback_survey_settings")
}

model FeedbackSurveyLogicRule {
  id               String   @id @default(uuid())
  surveyId         String
  survey           FeedbackSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  sourceQuestionId String
  sourceQuestion   FeedbackSurveyQuestion @relation("LogicRuleSource", fields: [sourceQuestionId], references: [id], onDelete: Cascade)
  operator         String
  value            String   @db.Text
  action           String
  targetQuestionId String?
  targetQuestion   FeedbackSurveyQuestion? @relation("LogicRuleTargetQuestion", fields: [targetQuestionId], references: [id], onDelete: SetNull)
  targetSectionId  String?
  targetSection    FeedbackSurveySection? @relation("LogicTargetSection", fields: [targetSectionId], references: [id], onDelete: SetNull)
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([surveyId])
  @@index([sourceQuestionId])
  @@map("feedback_survey_logic_rules")
}

model FeedbackSurveyAssignment {
  id          String         @id @default(uuid())
  surveyId    String
  survey      FeedbackSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt  DateTime       @default(now())
  completedAt DateTime?

  @@unique([surveyId, userId])
  @@index([userId])
  @@map("feedback_survey_assignments")
}

model FeedbackSurveyShareLink {
  id           String   @id @default(uuid())
  surveyId     String
  survey       FeedbackSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  token        String   @unique
  expiresAt    DateTime?
  requireLogin Boolean  @default(true)
  isActive     Boolean  @default(true)
  createdById  String?
  createdBy    User?    @relation("FeedbackShareLinkCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())

  submissions FeedbackSurveySubmission[]

  @@index([surveyId])
  @@map("feedback_survey_share_links")
}

model FeedbackSurveySubmission {
  id            String   @id @default(uuid())
  surveyId      String
  survey        FeedbackSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  shareLinkId   String?
  shareLink     FeedbackSurveyShareLink? @relation(fields: [shareLinkId], references: [id], onDelete: SetNull)
  sessionToken  String?  @unique
  submittedAt   DateTime?
  isComplete    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  answers FeedbackSurveyAnswer[]

  @@index([surveyId])
  @@index([userId])
  @@map("feedback_survey_submissions")
}

model FeedbackSurveyAnswer {
  id           String   @id @default(uuid())
  submissionId String
  submission   FeedbackSurveySubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId   String
  question     FeedbackSurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value        String   @db.Text
  filePath     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([submissionId, questionId])
  @@index([questionId])
  @@map("feedback_survey_answers")
}

model FeedbackSurveyCollaborator {
  id        String   @id @default(uuid())
  surveyId  String
  survey    FeedbackSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  createdAt DateTime @default(now())

  @@unique([surveyId, userId])
  @@index([userId])
  @@map("feedback_survey_collaborators")
}

model FeedbackSurveyAction {
  id         String   @id @default(uuid())
  surveyId   String
  survey     FeedbackSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  actionType String
  fieldMap   Json
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([surveyId])
  @@map("feedback_survey_actions")
}

model FeedbackSurveyResponse {
  id         String                 @id @default(uuid())
  surveyId   String
  survey     FeedbackSurvey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  questionId String
  question   FeedbackSurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer     String                 @db.Text
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@unique([questionId, userId])
  @@index([surveyId])
  @@index([userId])
  @@map("feedback_survey_responses")
}

// Email audit trail (SMTP send events)
model EmailLog {
  id              String   @id @default(uuid())
  recipientEmail  String
  subject         String
  template        String
  status          String   // SENT | FAILED
  relatedEmployeeId String?
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([recipientEmail])
  @@index([relatedEmployeeId])
  @@map("email_logs")
}

// Email Management module
model EmailTemplate {
  id        String   @id @default(uuid())
  name      String
  fromEmail String?  // optional (defaults to EMAIL_FROM)
  cc        String?  @db.Text
  bcc       String?  @db.Text
  subject   String
  html      String   @db.Text
  variables String?  @db.Text // JSON string array for placeholder suggestions
  isActive  Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  triggers EmailTrigger[]
  queueItems EmailQueueItem[]

  @@unique([name])
  @@map("email_templates")
}

model EmailTrigger {
  id           String   @id @default(uuid())
  name         String
  eventKey     String   // e.g. EMPLOYEE_CREATED_ERP_ACCESS
  templateId   String
  template     EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  enabled      Boolean  @default(true)
  recipients   String?  @db.Text // JSON: { to, cc, bcc } mapping rules
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([eventKey])
  @@map("email_triggers")
}

model EmailQueueItem {
  id          String   @id @default(uuid())
  templateId  String?
  template    EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  toEmail     String
  cc          String?  @db.Text
  bcc         String?  @db.Text
  subject     String
  html        String   @db.Text
  status      String   @default("PENDING") // PENDING | SENDING | SENT | FAILED
  attempts    Int      @default(0)
  lastError   String?  @db.Text
  relatedEmployeeId String?
  scheduledAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([toEmail])
  @@map("email_queue")
}

// Workplace company policies (acknowledgements per user)
model CompanyPolicy {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  department  String   @default("General")
  fileName    String?
  filePath    String?  // stored filename under uploads/policies
  fileType    String   @default("PDF")
  fileSize    String   @default("—")
  isActive    Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation("CompanyPolicyCreator", fields: [createdById], references: [id])
